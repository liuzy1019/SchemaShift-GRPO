# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.pytest_cache/

# 虚拟环境
venv/
.venv/

# 日志
logs/
*.log

# 数据（从 HF 下载或脚本生成，不入库；clone 后跑 scripts/download_data.py + scripts/generate_perturbations.py 复现）
data/*.json
data/*.jsonl
data/possible_answer/
!data/.gitkeep
!data/README.md

# 实验结果
experiments/results/*
!experiments/.gitkeep

# 训练运行时产物
outputs/
wandb/
checkpoints/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 环境变量
.env

# OS
.DS_Store
Thumbs.db

# PyTorch
*.pt
*.pth
verl/

# 参考仓库（外部 clone，仅供阅读）
_ref_tmp/

# 敏感凭据（任何 token 文件都不进 commit）
git_token.MD
*.token
*token.txt

# 诊断临时产物
pyspy_*/
.coverage
htmlcov/
